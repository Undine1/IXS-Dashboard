#!/usr/bin/env node
const fs = require('fs');
const path = require('path');
const { ethers } = require('ethers');

// Load .env.local into process.env if present (robust parsing)
try {
  const envFile = path.join(__dirname, '..', '.env.local');
  if (fs.existsSync(envFile)) {
    const lines = fs.readFileSync(envFile, 'utf8').split(/\r?\n/);
    for (const line of lines) {
      if (!line || line.trim().startsWith('#')) continue;
      const idx = line.indexOf('=');
      if (idx === -1) continue;
      const key = line.substring(0, idx).trim();
      const val = line.substring(idx + 1);
      if (key) process.env[key] = val;
    }
  }
} catch (e) {
  console.warn('Failed to load .env.local:', e.message || e);
}

// Configuration
const DEFAULT_POOLS = [
  '0xd093a031df30f186976a1e2936b16d95ca7919d6'
].map(p => p.toLowerCase());
const POOLS = (process.env.POOLS || DEFAULT_POOLS.join(',')).split(',').map(p => p.trim().toLowerCase()).filter(Boolean);
// Prefer Alchemy (if provided) then a more reliable public RPC as the default; allow override via env.
const DEFAULT_RPC = process.env.ALCHEMY_POLYGON || process.env.POLYGON_RPC || 'https://rpc.ankr.com/polygon';
// If the user has provided paid RPC keys/URLs, prefer them first (ALCHEMY, QUICKNODE)
const extraRpcs = [];
if (process.env.ALCHEMY_KEY || process.env.ALCHEMY_POLYGON) {
  const key = process.env.ALCHEMY_POLYGON || process.env.ALCHEMY_KEY;
  extraRpcs.push(`https://polygon-mainnet.g.alchemy.com/v2/${key}`);
}
if (process.env.QUICKNODE_URL) {
  extraRpcs.push(process.env.QUICKNODE_URL);
}
// Optional: comma-separated list of RPC endpoints for provider failover
const envList = (process.env.POLYGON_RPC_LIST || '');
const envRpcs = envList ? envList.split(',').map(s => s.trim()).filter(Boolean) : [];
// Build RPC list: prefer paid endpoints (Alchemy/QuickNode), then any provided list, then DEFAULT_RPC.
// Do NOT auto-append public high-variance endpoints like https://polygon-rpc.com to avoid accidental overuse.
const RPC_LIST = Array.from(new Set([...(extraRpcs || []), ...(envRpcs || []), DEFAULT_RPC]));
const DATA_FILE = path.join(__dirname, '..', 'public', 'data', 'pool_volume.json');
const CHECKPOINT_FILE = path.join(__dirname, '..', 'public', 'data', 'pool_volume_checkpoint.json');
const TRANSFER_TOPIC = '0xddf252ad1be2c89b69c2b068fc378daa952ba7f163c4a11628f55a4df523b3ef';

// Only track USDC on Polygon (1 USDC = $1)
const USDC = (process.env.POLYGON_USDC || '0x2791bca1f2de4661ed88a30c99a7a9449aa84174').toLowerCase();
const USDC_DECIMALS = 6;

const BLOCKS_PER_DAY = Number(process.env.BLOCKS_PER_DAY || 6000);
// Provider health/cooldown settings
const PROVIDER_COOLDOWN_MS = Number(process.env.PROVIDER_COOLDOWN_MS || 60_000);
const PROVIDER_RATE_LIMIT_CODES = ['-32090', '429']; // common rate-limit indicators
// Per-provider minimum interval between requests (ms)
const REQUEST_MIN_INTERVAL_MS = Number(process.env.REQUEST_MIN_INTERVAL_MS || 500);
const PROVIDER_MAX_BAN_MS = Number(process.env.PROVIDER_MAX_BAN_MS || PROVIDER_COOLDOWN_MS * 10);

// Global concurrency limiter for RPC calls to avoid hammering providers
const GLOBAL_RPC_CONCURRENCY = Number(process.env.GLOBAL_RPC_CONCURRENCY || 1);
let _globalRunning = 0;
const _globalQueue = [];
function acquireGlobal() {
  if (_globalRunning < GLOBAL_RPC_CONCURRENCY) {
    _globalRunning++;
    return Promise.resolve();
  }
  return new Promise((res) => {
    _globalQueue.push(res);
  });


function releaseGlobal() {
  try {
    _globalRunning = Math.max(0, _globalRunning - 1);
    const next = _globalQueue.shift();
    if (next) {
      _globalRunning++;
      try { next(); } catch (e) {}
    }
  } catch (e) {
    // ignore
  }
}
async function loadData() {
  try {
    const raw = fs.readFileSync(DATA_FILE, 'utf8');
    return JSON.parse(raw);
  } catch (e) {
    return { pools: {}, lastUpdated: 0 };
  }
}

async function saveData(data) {
  fs.writeFileSync(DATA_FILE, JSON.stringify(data, null, 2), 'utf8');
}

async function findBlockByTimestamp(provider, targetTs, latestBlock) {
  // Binary search for the lowest block where block.timestamp >= targetTs
  let low = 0;
  let high = latestBlock;
  while (low < high) {
    const mid = Math.floor((low + high) / 2);
    const b = await providerGetBlock(provider, mid);
    if (!b) { low = mid + 1; continue; }
    const ts = Number(b.timestamp);
    if (ts < targetTs) {
      low = mid + 1;
    } else {
      high = mid;
    }
  }
  return low;
}

async function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

// Ensure we don't hammer a single provider: wait if lastRequestAt is too recent
async function ensureProviderPacing(selObj) {
  try {
    if (!selObj) return;
    const last = selObj.lastRequestAt || 0;
    const now = Date.now();
    const since = now - last;
    const wait = REQUEST_MIN_INTERVAL_MS - since;
    if (wait > 0) {
      await sleep(wait + Math.floor(Math.random() * 50));
    }
    selObj.lastRequestAt = Date.now();
  } catch (e) {
    // ignore pacing failures
  }
}

async function providerGetBlock(_provider, blockNumber) {
  const maxRetries = 6;
  let attempt = 0;
  while (true) {
    let selObj = null;
    try {
      await acquireGlobal();
      selObj = pickProvider(attempt);
      const sel = selObj.provider;
      await ensureProviderPacing(selObj);
      if (attempt > 0 && providerPool.length > 1) console.warn(`Using provider ${selObj.url} (attempt ${attempt})`);
      const b = await sel.getBlock(blockNumber);
      selObj.successes++;
      return b;
    } catch (e) {
      try {
        if (selObj) {
          selObj.failures = (selObj.failures || 0) + 1;
          selObj.lastFailureAt = Date.now();
          const msg = (e && e.message) ? String(e.message).toLowerCase() : '';
            if (msg.includes('too many') || msg.includes('rate limit') || String(e.code).includes('-32090') || String(e.status || '').includes('429')) {
              // Exponential backoff ban based on failure count; cap at PROVIDER_MAX_BAN_MS
              let banMs = PROVIDER_COOLDOWN_MS * Math.pow(2, Math.max(0, selObj.failures - 1));
              const m = msg.match(/retry in\s*(\d+)s/);
              if (m) {
                const s = Number(m[1]);
                if (Number.isFinite(s) && s > 0) banMs = Math.max(banMs, s * 1000);
              }
              banMs = Math.min(banMs, PROVIDER_MAX_BAN_MS);
              selObj.bannedUntil = Date.now() + banMs;
              console.warn(`Provider ${selObj.url} temporarily banned until ${new Date(selObj.bannedUntil).toISOString()} (ban ${banMs}ms) due to rate-limit`);
            }
        }
      } catch (er) {}
      attempt++;
      if (attempt > maxRetries) throw e;
      const wait = Math.min(30000, 1000 * Math.pow(2, attempt));
      console.warn(`getBlock failed (attempt ${attempt}), retrying in ${wait}ms:`, e.message || e);
      await sleep(wait + Math.floor(Math.random() * 200));
    }
    finally {
      try { releaseGlobal(); } catch (er) {}
    }
  }
}

async function providerGetBlockNumber() {
  const maxRetries = 4;
  let attempt = 0;
  while (true) {
    let selObj = null;
    try {
      await acquireGlobal();
      selObj = pickProvider(attempt);
      const sel = selObj.provider;
      await ensureProviderPacing(selObj);
      if (attempt > 0 && providerPool.length > 1) console.warn(`Using provider ${selObj.url} for getBlockNumber (attempt ${attempt})`);
      const n = await sel.getBlockNumber();
      selObj.successes++;
      return n;
    } catch (e) {
      try {
        if (selObj) {
          selObj.failures = (selObj.failures || 0) + 1;
          selObj.lastFailureAt = Date.now();
          const msg = (e && e.message) ? String(e.message).toLowerCase() : '';
          if (msg.includes('too many') || msg.includes('rate limit') || String(e.code).includes('-32090') || String(e.status || '').includes('429')) {
            let banMs = PROVIDER_COOLDOWN_MS;
            const m = msg.match(/retry in\s*(\d+)s/);
            if (m) {
              const s = Number(m[1]);
              if (Number.isFinite(s) && s > 0) banMs = Math.max(banMs, s * 1000);
            }
            selObj.bannedUntil = Date.now() + banMs;
            console.warn(`Provider ${selObj.url} temporarily banned until ${new Date(selObj.bannedUntil).toISOString()} (ban ${banMs}ms) due to rate-limit`);
          }
        }
      } catch (er) {}
      attempt++;
      if (attempt > maxRetries) throw e;
      const wait = 1000 * Math.pow(2, attempt);
      console.warn(`getBlockNumber failed (attempt ${attempt}), retrying in ${wait}ms:`, e.message || e);
      await sleep(wait);
    }
    finally {
      try { releaseGlobal(); } catch (er) {}
    }
  }
}

// providerGetLogs: retries across configured providers, with per-attempt timeout.
// Rethrows range-too-large errors immediately so caller can shrink chunk.
async function providerGetLogs(filter, attemptTimeoutMs = 15000) {
  const maxRetries = 6;
  let attempt = 0;
  while (true) {
    let selObj = null;
    try {
      await acquireGlobal();
      selObj = pickProvider(attempt);
      const sel = selObj.provider;
      await ensureProviderPacing(selObj);
      if (attempt > 0 && providerPool.length > 1) console.warn(`Using provider ${selObj.url} for getLogs (attempt ${attempt})`);
      const req = sel.getLogs(filter);
      const res = await Promise.race([
        req,
        new Promise((_, rej) => setTimeout(() => rej(new Error('timeout')), attemptTimeoutMs))
      ]);
      try { logsProviderMap.push({ provider: selObj.url || 'unknown', fromBlock: filter.fromBlock, toBlock: filter.toBlock }); } catch (e) {}
      selObj.successes++;
      return res;
    } catch (e) {
      // If the provider explicitly complains the block range is too large, let caller handle shrinking immediately
      const msg = (e && e.message) ? String(e.message).toLowerCase() : '';
      if (msg.includes('range') || msg.includes('too large') || (e && e.code === -32062)) {
        throw e;
      }
      // mark the provider we just used as having failed
      try {
        if (selObj) {
          selObj.failures = (selObj.failures || 0) + 1;
          selObj.lastFailureAt = Date.now();
          // if rate-limit-like message, ban provider briefly
          const ratey = msg.includes('too many') || msg.includes('rate limit') || msg.includes('timeout') || String(e.code).includes('-32090') || String(e.status || '').includes('429');
          if (ratey) {
            // Exponential backoff ban based on failure count; cap at PROVIDER_MAX_BAN_MS
            selObj.failures = (selObj.failures || 0) + 1;
            let banMs = PROVIDER_COOLDOWN_MS * Math.pow(2, Math.max(0, selObj.failures - 1));
            const m = msg.match(/retry in\s*(\d+)s/);
            if (m) {
              const s = Number(m[1]);
              if (Number.isFinite(s) && s > 0) banMs = Math.max(banMs, s * 1000);
            }
            banMs = Math.min(banMs, PROVIDER_MAX_BAN_MS);
            selObj.bannedUntil = Date.now() + banMs;
            console.warn(`Provider ${selObj.url} temporarily banned until ${new Date(selObj.bannedUntil).toISOString()} (ban ${banMs}ms) due to rate-limit/timeout`);
          }
        }
      } catch (er) {}
      attempt++;
      if (attempt > maxRetries) throw e;
      const wait = Math.min(10000, 500 * Math.pow(2, attempt));
      console.warn(`getLogs failed (attempt ${attempt}), retrying in ${wait}ms:`, e.message || e);
      await sleep(wait + Math.floor(Math.random() * 200));
    }
    finally {
      try { releaseGlobal(); } catch (er) {}
    }
  }
}

// Provider pool will be built and health-probed at startup so we prefer healthy endpoints.
let providerPool = [];
let nextProviderIndex = 0;

async function probeProvider(url, timeoutMs = 5000) {
  const start = Date.now();
  const prov = new ethers.JsonRpcProvider(url);
  try {
    const res = await Promise.race([
      prov.getBlockNumber(),
      new Promise((_, rej) => setTimeout(() => rej(new Error('probe-timeout')), timeoutMs))
    ]);
    return { url, provider: prov, ok: true, latency: Date.now() - start };
  } catch (e) {
    return { url, provider: prov, ok: false, latency: Number.MAX_SAFE_INTEGER, err: String(e && e.message) };
  }
}

async function initProviderPool() {
  const probes = await Promise.all(RPC_LIST.map(u => probeProvider(u, 5000)));
  // Sort healthy providers first by ok desc then latency
  const sorted = probes.slice().sort((a, b) => {
    if (a.ok !== b.ok) return a.ok ? -1 : 1;
    return a.latency - b.latency;
  });
  providerPool = sorted.map(p => ({ url: p.url, provider: p.provider, failures: 0, successes: 0, bannedUntil: 0, lastFailureAt: 0, lastRequestAt: 0 }));
  console.log('Initialized providerPool with order:', providerPool.map(p => `${p.url}${p.provider ? '' : ' (no prov)'}`));
  // If we found at least one OK provider, set the global RPC to that URL for direct calls
  if (providerPool.length > 0 && providerPool[0].url) process.env.POLYGON_RPC = providerPool[0].url;
}

function pickProvider(attempt = 0) {
  const now = Date.now();
  // Round-robin preference: start at nextProviderIndex and pick the first non-banned provider
  const len = providerPool.length;
  if (len === 0) throw new Error('No RPC providers configured');
  for (let i = 0; i < len; i++) {
    const idx = (nextProviderIndex + i) % len;
    const p = providerPool[idx];
    if (!p.bannedUntil || p.bannedUntil <= now) {
      // advance round-robin pointer for next call
      nextProviderIndex = (idx + 1) % len;
      return p;
    }
  }
  // If all are banned, pick the least recently failed provider (allow retry)
  const sorted = providerPool.slice().sort((a, b) => {
    if (a.failures !== b.failures) return a.failures - b.failures;
    return b.successes - a.successes;
  });
  // rotate pointer
  nextProviderIndex = (nextProviderIndex + 1) % len;
  return sorted[attempt % sorted.length];
}

// Map of which provider served which filter ranges during this run
const logsProviderMap = [];
// Fallback API call counters
let polygonscanCalls = 0;
let etherscanCalls = 0;
const POLYGONSCAN_DAILY_LIMIT = Number(process.env.POLYGONSCAN_DAILY_LIMIT || 100000);

// Adaptive fetch for a single fromBlock..toBlock window using dynamic chunking and retries.
async function fetchLogsAdaptive(fromBlock, toBlock, poolTopicEncoded, topicIndex, opts = {}) {
  const initialChunk = Number(opts.initialChunk || process.env.LOG_CHUNK || 1000);
  const MIN_CHUNK = Math.max(1, Number(opts.minChunk || process.env.MIN_LOG_CHUNK || 10));
  const MAX_ATTEMPTS_PER_CHUNK = Number(opts.maxAttempts || process.env.MAX_ATTEMPTS_PER_CHUNK || 5);
  const MAX_CHUNK_TIME_MS = Number(process.env.MAX_CHUNK_TIME_MS || 20000);
  const topics = [];
  topics[0] = TRANSFER_TOPIC;
  topics[1] = null; topics[2] = null;
  if (topicIndex === 1) topics[1] = poolTopicEncoded;
  if (topicIndex === 2) topics[2] = poolTopicEncoded;

  let results = [];
  let start = Number(fromBlock);
  const finalEnd = Number(toBlock);
  let currentChunk = initialChunk;

  // If a checkpoint exists for this pool+range, resume from there
  let checkpoints = {};
  try { checkpoints = JSON.parse(fs.readFileSync(CHECKPOINT_FILE, 'utf8') || '{}'); } catch (e) { checkpoints = {}; }
  const ckKey = `${poolTopicEncoded}:${fromBlock}:${toBlock}:${topicIndex}`;
  if (checkpoints[ckKey] && Number(checkpoints[ckKey].currentStart) > start) {
    start = Number(checkpoints[ckKey].currentStart);
    if (checkpoints[ckKey].currentChunk) currentChunk = Number(checkpoints[ckKey].currentChunk);
    console.log(`Resuming chunked fetch at ${start} (chunk=${currentChunk}) from checkpoint`);
  }

  while (start <= finalEnd) {
    let end = Math.min(finalEnd, start + currentChunk - 1);
    let attempt = 0;
    let success = false;
    let lastErr = null;
    const chunkStartTime = Date.now();
    while (attempt < MAX_ATTEMPTS_PER_CHUNK && !success) {
      attempt++;
      try {
        const filter = { address: USDC, fromBlock: start, toBlock: end, topics };
        const part = await providerGetLogs(filter, Math.max(8000, Math.min(15000, Math.floor(currentChunk * 10))));
        if (part && part.length) results.push(...part);
        success = true;
        // write checkpoint after successful chunk
        checkpoints[ckKey] = { currentStart: end + 1, currentChunk };
        try { fs.writeFileSync(CHECKPOINT_FILE, JSON.stringify(checkpoints, null, 2), 'utf8'); } catch (e) {}
        // advance
        start = end + 1;
        // gradually grow chunk back toward initial if we've been shrinking
        if (currentChunk < initialChunk) currentChunk = Math.min(initialChunk, currentChunk * 2);
      } catch (err) {
        lastErr = err;
        const msg = (err && err.message) ? err.message.toLowerCase() : '';
        console.warn(`chunk ${start}-${end} attempt ${attempt} failed:`, msg || err);
        // If provider complains range too large, shrink chunk aggressively and retry quickly
        if (msg.includes('range') || msg.includes('too large') || (err && err.code === -32062)) {
          const newChunk = Math.max(MIN_CHUNK, Math.floor(currentChunk / 4));
          currentChunk = Math.max(MIN_CHUNK, newChunk);
          end = Math.min(finalEnd, start + currentChunk - 1);
          console.warn(`Range error detected; shrinking chunk to ${currentChunk} and retrying ${start}-${end}`);
          await sleep(100 + Math.floor(Math.random() * 150));
          continue;
        }
        // If provider rate-limited or transient, backoff and retry (providerGetLogs rotates providers)
        const wait = Math.min(10000, 200 * Math.pow(2, Math.min(attempt, 6)));
        await sleep(wait + Math.floor(Math.random() * 150));
        // if we've spent too long on this chunk, break to sub-chunking to avoid long hangs
        if (Date.now() - chunkStartTime > MAX_CHUNK_TIME_MS) {
          console.warn(`Chunk ${start}-${end} exceeded max time ${MAX_CHUNK_TIME_MS}ms, falling back to sub-chunking.`);
          break;
        }
      }
    }

    if (!success) {
      // final attempt failed for this chunk range: try sub-chunking into single-blocks to guarantee coverage
      console.warn(`Final failure for chunk ${start}-${end}, falling back to sub-chunking single-blocks to guarantee coverage.`);
      let subStart = start;
      while (subStart <= end) {
        const subEnd = subStart; // single block
        try {
          const filter = { address: USDC, fromBlock: subStart, toBlock: subEnd, topics };
          const part2 = await providerGetLogs(filter, 4000);
          if (part2 && part2.length) results.push(...part2);
        } catch (err2) {
          console.warn(`single-block fetch failed ${subStart}-${subEnd}:`, err2.message || err2);
          // If still failing, give up this single block temporarily but record to checkpoint so we can retry later
          // Move on to next block to avoid infinite loop
        }
        // persist progress
        checkpoints[ckKey] = { currentStart: subEnd + 1, currentChunk: MIN_CHUNK };
        try { fs.writeFileSync(CHECKPOINT_FILE, JSON.stringify(checkpoints, null, 2), 'utf8'); } catch (e) {}
        subStart = subEnd + 1;
      }
      // advance the main pointer past this chunk
      start = end + 1;
      // continue with same or smaller chunk
      currentChunk = Math.max(MIN_CHUNK, Math.floor(currentChunk / 2));
    }
  }

  // cleanup checkpoint for this key on full success
  try {
    const ck = JSON.parse(fs.readFileSync(CHECKPOINT_FILE, 'utf8') || '{}');
    delete ck[ckKey];
    fs.writeFileSync(CHECKPOINT_FILE, JSON.stringify(ck, null, 2), 'utf8');
  } catch (e) {}

  return results;
}

async function etherscanTokentxSum(pool, startBlock, endBlock) {
  const key = process.env.ETHERSCAN_API_KEY || '';
  if (!key) throw new Error('No ETHERSCAN_API_KEY set');
  // Use Polygonscan for chain=137 to avoid cross-chain issues
  const base = 'https://api.polygonscan.com/api';
  const offset = 1000; // page size (smaller to be safe)
  let page = 1;
  let total = 0n;
  while (true) {
    if (polygonscanCalls >= POLYGONSCAN_DAILY_LIMIT) throw new Error('Polygonscan daily quota exhausted');
    const url = `${base}?module=account&action=tokentx&contractaddress=${USDC}&address=${pool}&startblock=${startBlock}&endblock=${endBlock}&page=${page}&offset=${offset}&sort=asc&apikey=${key}`;
    console.log(`Polygonscan fallback request page ${page}`);
    polygonscanCalls += 1;
    const res = await fetch(url);
    if (!res.ok) throw new Error(`Polygonscan HTTP ${res.status}`);
    const json = await res.json();
    if (!json) break;
    if (json.status === '0' && (!json.result || json.result.length === 0)) break;
    const arr = json.result || [];
    for (const t of arr) {
      try {
        if ((t.contractAddress || '').toLowerCase() !== USDC) continue;
        const bn = BigInt(t.value || '0');
        total += bn;
      } catch (e) {
        // ignore
      }
    }
    if (arr.length < offset) break;
    page += 1;
    // throttle to respect 5 req/s (sleep >= 210ms)
    await sleep(220);
  }
  return Number(ethers.formatUnits(total, USDC_DECIMALS));
}

async function main() {
  // Initialize provider pool (probe and order providers by health/latency)
  await initProviderPool();
  const provider = new ethers.JsonRpcProvider(process.env.POLYGON_RPC || DEFAULT_RPC);
  const latestBlock = await providerGetBlockNumber(provider);
  const nowTs = Math.floor(Date.now() / 1000);
  const WINDOW_SECONDS = Number(process.env.WINDOW_SECONDS || 24 * 3600);
  const startTs = nowTs - WINDOW_SECONDS;

  console.log(`Latest block: ${latestBlock}, now: ${nowTs}, windowStartTs: ${startTs}`);

  // Find exact block bounds for the 24h window
  const endBlock = latestBlock;
  const startBlock = await findBlockByTimestamp(provider, startTs, latestBlock);

  console.log(`Exact block window: ${startBlock}..${endBlock}`);

  const data = await loadData();
  if (!data.pools) data.pools = {};
  const runPools = [];

  for (const pool of POOLS) {
    const poolTopicEncoded = '0x' + pool.replace(/^0x/, '').padStart(64, '0');
    // Respect any previously processed block for this pool to make runs idempotent
    const prevProcessed = (data.pools[pool] && data.pools[pool].lastProcessedBlock) || 0;
    let poolStart = Math.max(startBlock, Number(prevProcessed) + 1);
    if (poolStart > endBlock) {
      console.log(`Pool ${pool} already processed up to ${prevProcessed}, skipping.`);
      continue;
    }

    console.log(`Scanning USDC transfers for pool ${pool} in blocks ${poolStart}..${endBlock} (prevProcessed=${prevProcessed})`);
    let logsFrom = [];
    let logsTo = [];
    let usedFallback = false;
    try {
      logsFrom = await fetchLogsAdaptive(poolStart, endBlock, poolTopicEncoded, 1);
      logsTo = await fetchLogsAdaptive(poolStart, endBlock, poolTopicEncoded, 2);
    } catch (e) {
      console.error('Adaptive fetch failed for pool', pool, ' - will try Etherscan fallback:', e.message || e);
    }
    const combinedLogs = logsFrom.concat(logsTo);
    // Deduplicate logs by txHash+logIndex (use combinedLogs after possible retries/fallback)
    let totalDayUsd = 0;
    // If adaptive fetch left a checkpoint, it means some chunks couldn't be fetched reliably.
    // Try Etherscan fallback for the whole window before giving up; if that fails, try one more aggressive pass.
    const ckKey1 = `${poolTopicEncoded}:${poolStart}:${endBlock}:1`;
    const ckKey2 = `${poolTopicEncoded}:${poolStart}:${endBlock}:2`;
    let MAX_PASSES = Number(process.env.MAX_FETCH_PASSES || 5);
    let pass = 0;
    let checkpointsAll = {};
    let anyIncomplete = false;
    let combinedLogsLocal = combinedLogs;
    try { checkpointsAll = JSON.parse(fs.readFileSync(CHECKPOINT_FILE, 'utf8') || '{}'); } catch (e) { checkpointsAll = {}; }
    anyIncomplete = Boolean(checkpointsAll[ckKey1] || checkpointsAll[ckKey2]);

    // Retry loop: try multiple aggressive passes before falling back to Etherscan
    while (pass < MAX_PASSES && !usedFallback) {
      // if no incomplete checkpoints and we have logs, we're done
      if ((!combinedLogsLocal || combinedLogsLocal.length === 0) || anyIncomplete) {
        if (pass > 0) console.log(`Pass ${pass}: retrying fetch for pool ${pool}`);
        // escalate aggressiveness on subsequent passes
        const opts = (pass === 0) ? {} : { minChunk: 1, maxAttempts: Math.min(64, 8 * Math.pow(2, pass)), initialChunk: Math.max(50, Math.min(500, Math.floor((Number(process.env.LOG_CHUNK || 1000) || 1000) / (pass + 1)))) };
        try {
          logsFrom = await fetchLogsAdaptive(poolStart, endBlock, poolTopicEncoded, 1, opts);
          logsTo = await fetchLogsAdaptive(poolStart, endBlock, poolTopicEncoded, 2, opts);
          combinedLogsLocal = (logsFrom || []).concat(logsTo || []);
        } catch (e) {
          console.warn(`Pass ${pass} fetch encountered error:`, e.message || e);
        }
      }

      // reload checkpoints to see if progress was made
      try { checkpointsAll = JSON.parse(fs.readFileSync(CHECKPOINT_FILE, 'utf8') || '{}'); } catch (e) { checkpointsAll = {}; }
      anyIncomplete = Boolean(checkpointsAll[ckKey1] || checkpointsAll[ckKey2]);

      // if we have logs and no incomplete markers, stop retrying
      if (combinedLogsLocal && combinedLogsLocal.length > 0 && !anyIncomplete) {
        combinedLogs = combinedLogsLocal;
        break;
      }

      pass++;
      await sleep(500 * pass + Math.floor(Math.random() * 300));
    }

    // If after retries we still have no complete coverage, try Etherscan fallback once
    try { checkpointsAll = JSON.parse(fs.readFileSync(CHECKPOINT_FILE, 'utf8') || '{}'); } catch (e) { checkpointsAll = {}; }
    anyIncomplete = Boolean(checkpointsAll[ckKey1] || checkpointsAll[ckKey2]);
    if ((!(combinedLogs && combinedLogs.length > 0) || anyIncomplete) && !usedFallback) {
      try {
        console.log('Final attempt: using Etherscan fallback to cover remaining window...');
        const es = await etherscanTokentxSum(pool, poolStart, endBlock);
        totalDayUsd = es;
        usedFallback = true;
        // remove any checkpoints for this pool+window since fallback covered it
        try {
          const ck = JSON.parse(fs.readFileSync(CHECKPOINT_FILE, 'utf8') || '{}');
          delete ck[ckKey1]; delete ck[ckKey2];
          fs.writeFileSync(CHECKPOINT_FILE, JSON.stringify(ck, null, 2), 'utf8');
        } catch (e) {}
      } catch (e) {
        console.warn('Etherscan fallback failed:', e.message || e);
      }
    } else {
      // Ensure combinedLogs variable reflects what we have after retries
      combinedLogs = combinedLogsLocal || combinedLogs;
    }

    

    if (!usedFallback) {
      if (!combinedLogs || combinedLogs.length === 0) {
        console.log(`No USDC transfer logs for pool ${pool} in window.`);
        data.pools[pool] = data.pools[pool] || { total_usd: 0, lastUpdated: 0, lastProcessedBlock: 0 };
        data.pools[pool].lastUpdated = Date.now();
        if (anyIncomplete) {
          // Determine last successfully processed block from checkpoint (if present)
          let last1 = prevProcessed;
          let last2 = prevProcessed;
          try { if (checkpointsAll[ckKey1]) last1 = Math.max(prevProcessed, Number(checkpointsAll[ckKey1].currentStart) - 1); } catch (e) {}
          try { if (checkpointsAll[ckKey2]) last2 = Math.max(prevProcessed, Number(checkpointsAll[ckKey2].currentStart) - 1); } catch (e) {}
          const lastProcessed = Math.max(last1, last2);
          data.pools[pool].lastProcessedBlock = lastProcessed;
          console.log(`Incomplete coverage detected; advancing lastProcessedBlock to last successful ${lastProcessed} (will resume next run)`);
        } else {
          data.pools[pool].lastProcessedBlock = endBlock;
        }
        continue;
      }

      // Deduplicate
      const seen = new Set();
      const deduped = [];
      for (const l of combinedLogs) {
        const key = `${l.transactionHash}-${String(l.logIndex)}`;
        if (!seen.has(key)) { seen.add(key); deduped.push(l); }
      }

      let tokenSum = 0n;
      for (const l of deduped) {
        try {
          tokenSum += ethers.toBigInt(l.data);
        } catch (e) {
          // ignore malformed
        }
      }
      const tokenSumFloat = Number(ethers.formatUnits(tokenSum, USDC_DECIMALS));
      totalDayUsd = tokenSumFloat; // 1 USDC = $1
    }

    const prev = Number((data.pools[pool] && data.pools[pool].total_usd) || 0);
    const updated = prev + totalDayUsd;
    // determine lastProcessedBlock based on whether we achieved full coverage or left checkpoints
    let finalProcessed = endBlock;
    try {
      const ck = JSON.parse(fs.readFileSync(CHECKPOINT_FILE, 'utf8') || '{}');
      const last1 = ck[`${poolTopicEncoded}:${poolStart}:${endBlock}:1`] ? (Number(ck[`${poolTopicEncoded}:${poolStart}:${endBlock}:1`].currentStart) - 1) : null;
      const last2 = ck[`${poolTopicEncoded}:${poolStart}:${endBlock}:2`] ? (Number(ck[`${poolTopicEncoded}:${poolStart}:${endBlock}:2`].currentStart) - 1) : null;
      if (!usedFallback && (last1 !== null || last2 !== null)) {
        finalProcessed = Math.max(prevProcessed, Number(last1 || prevProcessed), Number(last2 || prevProcessed));
      }
    } catch (e) {}

    data.pools[pool] = Object.assign({}, data.pools[pool] || {}, {
      total_usd: Number(updated.toFixed(2)),
      lastUpdated: Date.now(),
      lastProcessedBlock: finalProcessed
    });

    runPools.push({
      pool,
      dayUsd: totalDayUsd,
      prev,
      updated: data.pools[pool].total_usd,
      usedFallback: Boolean(usedFallback),
      lastProcessedBlock: data.pools[pool].lastProcessedBlock
    });

    console.log(`Pool ${pool}: dayUsd=${totalDayUsd} -> prev=${prev} updated=${data.pools[pool].total_usd}`);
  }

  data.lastUpdated = Date.now();
  await saveData(data);
  console.log('Saved updated pool totals.');

  // Persist run summary for audit / future reference
  try {
    const runsFile = path.join(__dirname, '..', 'public', 'data', 'pool_volume_runs.json');
    let runs = [];
    try {
      runs = JSON.parse(fs.readFileSync(runsFile, 'utf8')) || [];
    } catch (e) { runs = []; }
    const runSummary = {
      timestamp: Date.now(),
      latestBlock,
      windowStartTs: startTs,
      startBlock,
      endBlock,
      rpc_list: RPC_LIST,
      pools: runPools,
      logsProviders: logsProviderMap,
      polygonscanCalls,
      etherscanCalls,
      providers: providerPool.map(p => ({ url: p.url, failures: p.failures, successes: p.successes, bannedUntil: p.bannedUntil }))
    };
    runs.push(runSummary);
    // keep only recent 200 entries
    if (runs.length > 200) runs = runs.slice(runs.length - 200);
    fs.writeFileSync(runsFile, JSON.stringify(runs, null, 2), 'utf8');
    console.log('Saved run summary to', runsFile);
    // Evaluate alerting thresholds and write alert file for CI
    try {
      const alertFile = path.join(__dirname, '..', 'public', 'data', 'pool_volume_alert.json');
      const alertReasons = [];
      const POLYGONSCAN_ALERT_THRESHOLD = Number(process.env.ALERT_POLYGONSCAN_CALLS || 50);
      const PROVIDER_BAN_ALERT_THRESHOLD = Number(process.env.ALERT_PROVIDER_BANS || 1);
      if ((polygonscanCalls || 0) >= POLYGONSCAN_ALERT_THRESHOLD) alertReasons.push(`polygonscanCalls=${polygonscanCalls} >= ${POLYGONSCAN_ALERT_THRESHOLD}`);
      const now = Date.now();
      const bannedCount = providerPool.filter(p => p.bannedUntil && p.bannedUntil > now).length;
      if (bannedCount >= PROVIDER_BAN_ALERT_THRESHOLD) alertReasons.push(`providersBanned=${bannedCount} >= ${PROVIDER_BAN_ALERT_THRESHOLD}`);
      const alertObj = { alert: alertReasons.length > 0, reasons: alertReasons, summary: runSummary };
      fs.writeFileSync(alertFile, JSON.stringify(alertObj, null, 2), 'utf8');
      if (alertObj.alert) console.warn('ALERT: run exceeded configured thresholds:', alertReasons);
    } catch (e) { console.warn('Failed to write alert file:', e && e.message); }
  } catch (e) {
    console.warn('Failed to save run summary:', e.message || e);
  }
}

main().catch((e) => { console.error(e); process.exit(1); });
